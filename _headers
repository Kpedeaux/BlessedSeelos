# Cloudflare Pages — security & caching headers

/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; img-src 'self' data: https://www.google.com https://maps.gstatic.com https://maps.googleapis.com https://*.googleusercontent.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self'; frame-src https://www.google.com https://maps.google.com; connect-src 'self'; base-uri 'self'; form-action 'self'

# Long cache for fingerprintable assets (images)
/assets/img/*
  Cache-Control: public, max-age=31536000, immutable

/assets/icons/*
  Cache-Control: public, max-age=31536000, immutable

# CSS / JS — moderate cache, will revalidate on deploy
/assets/css/*
  Cache-Control: public, max-age=86400, must-revalidate

/assets/js/*
  Cache-Control: public, max-age=86400, must-revalidate

# HTML — short cache so updates are seen quickly
/*.html
  Cache-Control: public, max-age=600, must-revalidate
